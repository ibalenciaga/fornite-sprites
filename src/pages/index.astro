---
import catalog from '../../data/sprites.json'

const groups = Array.isArray(catalog?.sprites) ? catalog.sprites : []
const totalSprites = groups.reduce((count, group) => {
    const sprites = Array.isArray(group?.sprites) ? group.sprites : []
    return count + sprites.length
}, 0)
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Fortnite Sprites - Mi Coleccion</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@500;700;800&family=Space+Grotesk:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <link rel="stylesheet" href="/styles/global.css" />
    </head>
    <body>
        <div class="bg-glow bg-glow-1"></div>
        <div class="bg-glow bg-glow-2"></div>

        <main class="app-shell">
            <header class="hero">
                <p class="eyebrow">Coleccion</p>
                <h1>Sprites de Fortnite</h1>
                <p class="subtitle">El progreso se guarda en este navegador.</p>
                <div class="stats" id="stats" data-total={totalSprites}>
                    Conseguidos: 0 / {totalSprites}
                </div>
            </header>

            <section class="content">
                <div class="toolbar">
                    <button id="resetBtn" type="button">Reset coleccion</button>
                </div>

                <div id="grid" class="type-stack">
                    {
                        groups.map((group) => (
                            <section
                                class="sprite-type-section"
                                data-group-id={group.id}
                            >
                                <h3 class="sprite-type-title">
                                    {group.name}{' '}
                                    <small
                                        class="group-counter"
                                        data-group-counter={group.id}
                                    />
                                </h3>

                                <div class="sprite-grid">
                                    {(group.sprites || []).map((sprite) => (
                                        <article
                                            class="sprite-card"
                                            role="button"
                                            tabindex="0"
                                            aria-pressed="false"
                                            data-sprite-id={sprite.id}
                                            data-group={group.id}
                                        >
                                            <div class="image-wrap">
                                                <img
                                                    src={sprite.image}
                                                    alt={sprite.name}
                                                    loading="lazy"
                                                />
                                                <span class="collected-badge">
                                                    Conseguido
                                                </span>
                                            </div>
                                            <div class="card-footer">
                                                <h2>{sprite.name}</h2>
                                            </div>
                                        </article>
                                    ))}
                                </div>
                            </section>
                        ))
                    }
                </div>
            </section>
        </main>

        <script is:inline>
            const STORAGE_KEY = 'fortnite-sprites-collected-v1'
            const cards = Array.from(
                document.querySelectorAll('[data-sprite-id]'),
            )
            const stats = document.getElementById('stats')
            const resetBtn = document.getElementById('resetBtn')
            const groupCounterNodes = Array.from(
                document.querySelectorAll('[data-group-counter]'),
            )

            const safeParseIds = (value) => {
                if (!Array.isArray(value)) return []
                return value.filter(
                    (id) => typeof id === 'string' && id.length > 0,
                )
            }

            const loadCollected = () => {
                try {
                    const raw = localStorage.getItem(STORAGE_KEY)
                    if (!raw) return new Set()
                    return new Set(safeParseIds(JSON.parse(raw)))
                } catch {
                    return new Set()
                }
            }

            const saveCollected = (set) => {
                localStorage.setItem(
                    STORAGE_KEY,
                    JSON.stringify(Array.from(set).sort()),
                )
            }

            const updateStats = (collectedSet) => {
                const total = Number(stats?.dataset.total || cards.length)
                let collected = 0

                for (const card of cards) {
                    const id = card.dataset.spriteId
                    if (id && collectedSet.has(id)) collected += 1
                }

                if (stats) {
                    stats.textContent = `Conseguidos: ${collected} / ${total}`
                }
            }

            const updateGroupCounters = (collectedSet) => {
                for (const node of groupCounterNodes) {
                    const groupId = node.dataset.groupCounter
                    const groupCards = cards.filter(
                        (card) => card.dataset.group === groupId,
                    )
                    const total = groupCards.length
                    const collected = groupCards.filter((card) =>
                        collectedSet.has(card.dataset.spriteId),
                    ).length
                    node.textContent = `(${collected}/${total})`
                }
            }

            const applyCollectedStyles = (collectedSet) => {
                for (const card of cards) {
                    const id = card.dataset.spriteId
                    const isCollected = Boolean(id && collectedSet.has(id))
                    card.classList.toggle('is-collected', isCollected)
                    card.setAttribute('aria-pressed', String(isCollected))
                }
            }

            const setCollectedAndRender = (collectedSet) => {
                applyCollectedStyles(collectedSet)
                updateStats(collectedSet)
                updateGroupCounters(collectedSet)
            }

            let collectedSet = loadCollected()
            setCollectedAndRender(collectedSet)

            for (const card of cards) {
                const onToggle = () => {
                    const id = card.dataset.spriteId
                    if (!id) return

                    if (collectedSet.has(id)) {
                        collectedSet.delete(id)
                    } else {
                        collectedSet.add(id)
                    }

                    saveCollected(collectedSet)
                    setCollectedAndRender(collectedSet)
                }

                card.addEventListener('click', onToggle)
                card.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault()
                        onToggle()
                    }
                })
            }

            resetBtn?.addEventListener('click', () => {
                collectedSet = new Set()
                saveCollected(collectedSet)
                setCollectedAndRender(collectedSet)
            })
        </script>
    </body>
</html>
